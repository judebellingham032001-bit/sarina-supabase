<%- include('partials/navbar') %>
<div class="container mt-4">
    <!-- Filter Bulan -->
    <div class="mb-3 d-flex gap-2 align-items-center">
        <input type="month" id="filterBulan" class="form-control" style="width: 250px;" value="<%= filterBulan %>">
        <button class="btn btn-primary" onclick="cari()">Cari Tanggal Lama</button>
        <a href="/" class="btn btn-secondary">Reset</a>
    </div>

    <table class="table table-hover bg-white shadow-sm">
        <thead class="table-dark">
            <tr><th>TGL</th><th>SPX</th><th>JNE</th><th>JNT</th><th>SAME</th><th>TOTAL</th><th>AKSI</th></tr>
        </thead>
        <tbody>
            <% dataShipping.forEach(item => { %>
                <tr>
                    <td><%= item.Tanggal %></td>
                    <td><%= item.SPX %></td>
                    <td><%= item.JNE %></td>
                    <td><%= item.JNT %></td>
                    <td><%= item["SAMEDAY/INSTANT"] %></td>
                    <td class="fw-bold"><%= item["TOTAL Paket"] %></td>
                    <td><a href="/hapus/shipping/<%= item.ID %>" class="text-danger">Del</a></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<script>
function cari() {
    const b = document.getElementById('filterBulan').value;
    window.location.href = b ? `/?bulan=${b}` : '/';
}
</script>

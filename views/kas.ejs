<%- include('partials/navbar') %>

<div class="container" style="max-width: 500px; padding-bottom: 100px;">
    <!-- FILTER BULAN & TAHUN (DROPDOWN ONLY) -->
    <div class="p-3 bg-white shadow-sm mb-3" style="border-radius: 20px;">
        <div class="row g-2">
            <div class="col-5">
                <select id="bln" class="form-select border-0 bg-light rounded-3">
                    <option value="">Bulan</option>
                    <% ['01','02','03','04','05','06','07','08','09','10','11','12'].forEach((v, i) => { %>
                        <option value="<%= v %>" <%= selBulan == v ? 'selected' : '' %>><%= ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][i] %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-4">
                <select id="thn" class="form-select border-0 bg-light rounded-3">
                    <option value="2026" <%= selTahun == '2026' ? 'selected' : '' %>>2026</option>
                    <option value="2025" <%= selTahun == '2025' ? 'selected' : '' %>>2025</option>
                </select>
            </div>
            <div class="col-3">
                <button onclick="filter()" class="btn btn-primary w-100 rounded-3 fw-bold">Cari</button>
            </div>
        </div>
    </div>

    <!-- LIST TRANSAKSI -->
    <h6 class="fw-bold px-2 text-muted mb-3"><%= selBulan ? 'Hasil Filter' : '10 Transaksi Terakhir' %></h6>
    
    <% dataKas.forEach(item => { %>
        <div class="card border-0 shadow-sm p-3 mb-2" style="border-radius: 18px;">
            <div class="d-flex justify-content-between align-items-center">
                <div style="max-width: 65%;">
                    <div class="text-muted" style="font-size: 11px;"><%= formatTgl(item.Tanggal) %></div>
                    <div class="fw-bold text-dark" style="font-size: 14px;"><%= item.Keterangan %></div>
                    
                    <!-- FIX BUKTI: Memanggil nama kolom sesuai gambar Supabase Bos -->
                    <% let linkBukti = item["Bukti Transaksi"] || item.Bukti; %>
                    <% if(linkBukti && linkBukti != 'NULL') { %>
                        <a href="<%= linkBukti %>" target="_blank" class="badge bg-info text-decoration-none mt-1">📎 Bukti Transaksi</a>
                    <% } %>
                </div>
                <div class="text-end">
                    <% if(item.Debet > 0) { %>
                        <div class="text-success fw-bold">+<%= item.Debet.toLocaleString('id-ID') %></div>
                    <% } else { %>
                        <div class="text-danger fw-bold">-<%= item.Kredit.toLocaleString('id-ID') %></div>
                    <% } %>
                    <a href="/hapus/kas/<%= item.ID %>" class="text-muted small" onclick="return confirm('Hapus?')">Hapus</a>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<!-- TOMBOL TAMBAH MELAYANG -->
<button class="btn btn-primary shadow-lg position-fixed" data-bs-toggle="modal" data-bs-target="#inKas" style="bottom: 20px; right: 20px; width: 60px; height: 60px; border-radius: 50%; font-size: 24px; z-index: 1000;">+</button>

<!-- MODAL INPUT -->
<div class="modal fade" id="inKas" tabindex="-1"><div class="modal-dialog modal-dialog-centered p-3"><div class="modal-content border-0" style="border-radius: 20px;"><div class="modal-body p-4">
    <h5 class="fw-bold mb-4">Input Kas Baru</h5>
    <form action="/tambah-kas" method="POST">
        <div class="mb-2"><label class="small fw-bold">Tanggal</label><input type="date" name="tanggal" class="form-control bg-light border-0" required></div>
        <div class="mb-2"><label class="small fw-bold">Keterangan</label><input type="text" name="keterangan" class="form-control bg-light border-0" required></div>
        <div class="row g-2 mb-2">
            <div class="col"><label class="small fw-bold">Masuk</label><input type="number" name="debet" class="form-control bg-light border-0" value="0"></div>
            <div class="col"><label class="small fw-bold">Keluar</label><input type="number" name="kredit" class="form-control bg-light border-0" value="0"></div>
        </div>
        <div class="mb-4"><label class="small fw-bold">Link Bukti G-Drive</label><input type="text" name="bukti" class="form-control bg-light border-0"></div>
        <button class="btn btn-primary w-100 py-2 fw-bold">Simpan</button>
    </form>
</div></div></div></div>

<script>
    function filter() {
        const b = document.getElementById('bln').value;
        const t = document.getElementById('thn').value;
        if(b && t) window.location.href = `/kas?bulan=${b}&tahun=${t}`;
    }
</script>

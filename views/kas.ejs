<%- include('partials/navbar') %>
<div class="container mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card-custom p-4">
                <h6 class="fw-bold mb-3">Input Transaksi Kas</h6>
                <form action="/tambah-kas" method="POST">
                    <div class="mb-2"><label>Tanggal</label><input type="date" name="tanggal" class="form-control" required></div>
                    <div class="mb-2"><label>Keterangan</label><input type="text" name="keterangan" class="form-control" placeholder="Beli lakban, dsb" required></div>
                    <div class="mb-2"><label>Masuk (D)</label><input type="number" name="debet" class="form-control" value="0"></div>
                    <div class="mb-2"><label>Keluar (K)</label><input type="number" name="kredit" class="form-control" value="0"></div>
                    <div class="mb-3"><label>Link Bukti Foto</label><input type="text" name="bukti" class="form-control" placeholder="https://..."></div>
                    <button class="btn btn-primary w-100 fw-bold">Simpan Transaksi</button>
                </form>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card-custom p-3">
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <h6 class="fw-bold mb-0">Riwayat Mutasi</h6>
                    <div class="d-flex gap-2">
                        <input type="month" id="fBulan" class="form-control form-control-sm" value="<%= filterBulan %>">
                        <button onclick="cari()" class="btn btn-sm btn-dark px-3">Filter</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>TGL</th><th>KET</th><th>NOMINAL</th><th>BUKTI</th><th></th></tr></thead>
                        <tbody>
                            <% dataKas.forEach(item => { %>
                            <tr>
                                <td class="small"><%= item.Tanggal %></td>
                                <td class="fw-bold small"><%= item.Keterangan %></td>
                                <td class="text-end small">
                                    <span class="<%= item.Debet > 0 ? 'text-success' : 'text-danger' %>">
                                        <%= (item.Debet || item.Kredit).toLocaleString('id-ID') %>
                                    </span>
                                </td>
                                <td><% if(item.Bukti) { %><a href="<%= item.Bukti %>" target="_blank" class="small">Lihat</a><% } %></td>
                                <td><a href="/hapus/kas/<%= item.ID %>" class="text-danger small">✖</a></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script>function cari(){ window.location.href=`/kas?bulan=${document.getElementById('fBulan').value}`; }</script>
</body></html>

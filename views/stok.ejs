<%- include('partials/navbar') %>
<div class="container mt-4">
    <h3 class="mb-3">Inventory Stok</h3>
    <table class="table table-bordered bg-white shadow-sm">
        <thead class="table-dark">
            <tr><th>Nama Barang</th><th>Jumlah Stok</th><th>Aksi</th></tr>
        </thead>
        <tbody>
            <% dataStok.forEach(item => { %>
                <tr>
                    <td><%= item.Nama_Barang %></td>
                    <td><%= item.Stok %></td>
                    <td><a href="/hapus/stok/<%= item.ID %>" class="btn btn-sm btn-danger">Hapus</a></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

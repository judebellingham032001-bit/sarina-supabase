<%- include('partials/navbar') %>
<div class="container">
    <div class="card p-4">
        <h3 class="fw-bold mb-4">📊 Data Stok Barang</h3>
        <table class="table">
            <thead class="table-dark">
                <tr><th>Nama Barang</th><th>Jumlah</th><th>Aksi</th></tr>
            </thead>
            <tbody>
                <% dataStok.forEach(item => { %>
                <tr>
                    <!-- Coba panggil Nama_Barang atau Barang -->
                    <td class="fw-bold"><%= item.Nama_Barang || item.Barang || 'Nama Tidak Ditemukan' %></td>
                    <td><span class="badge bg-primary px-3"><%= item.Stok || 0 %></span></td>
                    <td><a href="/hapus/stok/<%= item.ID %>" class="text-danger">Hapus</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/navbar') %>

<div class="container pb-5">
    <div class="mb-4 text-center">
        <h2 class="fw-bold"><span style="color: #7928ca;">Mutasi Kas</span> 💸</h2>
        <p class="text-muted">Pantau terus cuan Sarina System!</p>
    </div>

    <div class="card-main">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-colorful">
                    <tr>
                        <th>TANGGAL</th>
                        <th>KETERANGAN</th>
                        <th class="text-end">NOMINAL</th>
                        <th class="text-center">BUKTI</th>
                        <th class="text-center">AKSI</th>
                    </tr>
                </thead>
                <tbody>
                    <% dataKas.forEach(item => { %>
                    <tr>
                        <td>
                            <div class="badge rounded-pill bg-light text-dark border p-2 px-3">
                                <%= item.Tanggal ? new Date(item.Tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'short'}) : '-' %>
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold" style="color: #333;"><%= item.Keterangan %></div>
                            <div class="text-muted" style="font-size: 10px;">REF-ID: <%= item.ID %></div>
                        </td>
                        <td class="text-end">
                            <% if (item.Debet > 0) { %>
                                <div class="badge bg-gradient-green fs-6 p-2 px-3">+ <%= item.Debet.toLocaleString('id-ID') %></div>
                            <% } else { %>
                                <div class="badge bg-gradient-red fs-6 p-2 px-3">- <%= item.Kredit.toLocaleString('id-ID') %></div>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <% if (item.Bukti) { %>
                                <a href="<%= item.Bukti %>" target="_blank" class="btn btn-sm btn-bukti px-3">Lihat 👀</a>
                            <% } else { %>
                                <span class="text-muted">No File</span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <a href="/hapus/kas/<%= item.ID %>" class="btn btn-sm btn-light border rounded-pill shadow-sm" onclick="return confirm('Hapus?')">🗑️</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

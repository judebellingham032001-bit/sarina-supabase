<%- include('partials/navbar') %>

<div class="container mt-4">
    <div class="row">
        <!-- FORM INPUT (Mobile Friendly) -->
        <div class="col-lg-4">
            <div class="card-pro p-4 mb-4">
                <h5 class="fw-bold mb-4">Tambah Transaksi</h5>
                <form action="/tambah-kas" method="POST">
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Tanggal</label>
                        <input type="date" name="tanggal" class="form-control form-control-lg border-0 bg-light" style="border-radius:12px" required>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Keterangan</label>
                        <input type="text" name="keterangan" class="form-control form-control-lg border-0 bg-light" placeholder="Contoh: Beli Bubble Wrap" style="border-radius:12px" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="small fw-bold text-muted">Masuk (Rp)</label>
                            <input type="number" name="debet" class="form-control border-0 bg-light" value="0" style="border-radius:12px">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="small fw-bold text-muted">Keluar (Rp)</label>
                            <input type="number" name="kredit" class="form-control border-0 bg-light" value="0" style="border-radius:12px">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="small fw-bold text-muted">Link Bukti (Opsional)</label>
                        <input type="text" name="bukti" class="form-control border-0 bg-light" placeholder="https://..." style="border-radius:12px">
                    </div>
                    <button class="btn btn-input btn-primary w-100 shadow-sm">Simpan Transaksi</button>
                </form>
            </div>
        </div>

        <!-- DAFTAR MUTASI -->
        <div class="col-lg-8">
            <div class="card-pro p-3">
                <div class="d-flex justify-content-between align-items-center px-2 mb-3">
                    <h6 class="fw-bold m-0">Riwayat Mutasi</h6>
                    <div class="d-flex gap-2">
                        <input type="month" id="fBulan" class="form-control form-control-sm border-0 bg-light" value="<%= filterBulan %>">
                        <button onclick="cari()" class="btn btn-sm btn-dark px-3 rounded-pill">Filter</button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Tanggal Transaksi</th>
                                <th>Deskripsi</th>
                                <th class="text-end">Nominal</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% dataKas.forEach(item => { %>
                            <tr>
                                <td style="white-space:nowrap">
                                    <div class="fw-bold" style="font-size: 0.85rem;">
                                        <%= formatTanggal(item.Tanggal) %>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold"><%= item.Keterangan %></div>
                                    <% if(item.Bukti) { %>
                                        <a href="<%= item.Bukti %>" target="_blank" class="text-primary x-small text-decoration-none">Lihat Bukti</a>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <% if(item.Debet > 0) { %>
                                        <span class="text-success fw-bold">+<%= item.Debet.toLocaleString('id-ID') %></span>
                                    <% } else { %>
                                        <span class="text-danger fw-bold">-<%= item.Kredit.toLocaleString('id-ID') %></span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <a href="/hapus/kas/<%= item.ID %>" class="text-muted opacity-50" onclick="return confirm('Hapus?')">✖</a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function cari() {
        window.location.href = `/kas?bulan=${document.getElementById('fBulan').value}`;
    }
</script>
</body>
</html>

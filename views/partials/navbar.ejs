<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary-bank: #0060af; --bg-light: #f8fafc; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-light); color: #1e293b; }
        .navbar { background: white !important; border-bottom: 3px solid var(--primary-bank); padding: 12px 0; sticky-top; }
        .navbar-brand { font-weight: 800; color: var(--primary-bank) !important; letter-spacing: -0.5px; }
        .nav-link { font-weight: 600; color: #64748b !important; padding: 8px 16px !important; border-radius: 10px; transition: 0.3s; }
        .nav-link.active { background: #e0f2fe; color: var(--primary-bank) !important; }
        
        .card-bank { background: white; border-radius: 20px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.03); overflow: hidden; }
        .table { margin-bottom: 0; }
        .table th { background: #f1f5f9; color: #475569; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; padding: 16px; border: none; }
        .table td { padding: 16px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; font-size: 14px; }
        
        /* Mobile Fix */
        @media (max-width: 768px) {
            .container { padding: 12px; }
            .table td, .table th { padding: 12px 8px; font-size: 12px; }
            .btn-bukti { font-size: 10px !important; padding: 4px 8px !important; }
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand navbar-light shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">SARINA<span style="color:#334155">SYSTEM</span></a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link <%= menu === 'shipping' ? 'active' : '' %>" href="/">Shipping</a>
            <a class="nav-link <%= menu === 'stok' ? 'active' : '' %>" href="/stok">Stok</a>
            <a class="nav-link <%= menu === 'kas' ? 'active' : '' %>" href="/kas">Kas</a>
        </div>
    </div>
</nav>

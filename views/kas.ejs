<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #007AFF; --dark: #1C1C1E; --bg: #F2F2F7; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg); color: var(--dark); overflow-x: hidden; }
        
        /* Navbar Modern */
        .navbar { background: white !important; border-bottom: 1px solid #E5E5EA; padding: 18px 0; sticky-top; }
        .navbar-brand { font-weight: 800; letter-spacing: -1px; color: var(--dark) !important; font-size: 1.4rem; }
        .nav-link { font-weight: 600; color: #8E8E93 !important; font-size: 0.95rem; padding: 8px 16px !important; }
        .nav-link.active { color: var(--primary) !important; background: rgba(0,122,255,0.05); border-radius: 12px; }

        /* Card Apple Style */
        .card-pro { background: white; border-radius: 20px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.03); margin-bottom: 20px; }
        .btn-input { background: var(--primary); border: none; border-radius: 14px; padding: 12px; font-weight: 700; transition: 0.3s; }
        .btn-input:hover { background: #0056b3; transform: scale(1.02); }

        /* Table CSS */
        .table { margin-bottom: 0; }
        .table thead th { background: #F9F9F9; border: none; color: #8E8E93; font-size: 11px; text-transform: uppercase; padding: 15px; }
        .table td { border-top: 1px solid #F2F2F7; padding: 18px 15px; vertical-align: middle; font-size: 0.9rem; }
        
        /* Responsive Table for Mobile */
        @media (max-width: 768px) {
            .table-responsive { border: none; }
            .navbar-brand { font-size: 1.1rem; }
            .nav-link { font-size: 0.8rem; padding: 6px 10px !important; }
            .container { padding: 15px; }
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand navbar-light sticky-top shadow-sm">
    <div class="container">
        <a class="navbar-brand" href="/">SARINA <span style="color:var(--primary)">PRO</span></a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link <%= menu === 'shipping' ? 'active' : '' %>" href="/">Shipping</a>
            <a class="nav-link <%= menu === 'stok' ? 'active' : '' %>" href="/stok">Stok</a>
            <a class="nav-link <%= menu === 'kas' ? 'active' : '' %>" href="/kas">Kas</a>
        </div>
    </div>
</nav>

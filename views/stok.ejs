<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Stok Sarina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('partials/navbar') %>
<div class="container">
    <form action="/stok/tambah" method="POST" class="row g-2 mb-4 p-3 bg-white shadow-sm rounded">
        <div class="col-md-5"><input type="text" name="nama" class="form-control" placeholder="Nama Barang" required></div>
        <div class="col-md-3"><input type="number" name="masuk" class="form-control" placeholder="Masuk"></div>
        <div class="col-md-3"><input type="number" name="keluar" class="form-control" placeholder="Keluar"></div>
        <div class="col-md-1"><button type="submit" class="btn btn-primary w-100">OK</button></div>
    </form>
    <table class="table table-hover bg-white shadow-sm rounded">
        <thead class="table-primary">
            <tr><th>BARANG</th><th>MASUK</th><th>KELUAR</th><th>AKSI</th></tr>
        </thead>
        <tbody>
            <% dataStok.forEach(item => { %>
                <tr>
                    <td><%= item.nama_barang %></td><td><%= item.masuk %></td><td><%= item.keluar %></td>
                    <td><a href="/hapus/stok/<%= item.ID %>" class="text-danger" onclick="return confirm('Hapus?')">Del</a></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
</body>
</html>
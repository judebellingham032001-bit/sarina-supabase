<%- include('partials/navbar') %>
<div class="container">
    <h2 class="fw-bold mb-4 text-center">📈 Stok Barang <span style="color: #ff0080;">Ready</span></h2>
    <div class="row g-3">
        <% dataStok.forEach(item => { %>
            <div class="col-md-6 col-lg-4">
                <div class="card-main p-4 border-start border-5" style="border-color: #7928ca !important;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="fw-bold mb-0"><%= item.Nama_Barang || item.Barang %></h5>
                            <p class="text-muted small mb-0">ID: <%= item.ID %></p>
                        </div>
                        <div class="text-end">
                            <h3 class="fw-bold text-primary mb-0"><%= item.Stok || 0 %></h3>
                            <span class="small text-muted">UNIT</span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/hapus/stok/<%= item.ID %>" class="btn btn-sm btn-outline-danger w-100 rounded-pill">Hapus Stok</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
</body></html>

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Shipping Sarina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<%- include('partials/navbar') %>
<div class="container">
    <form action="/shipping/tambah" method="POST" class="row g-2 mb-4 p-3 bg-white shadow-sm rounded">
        <div class="col-md-3"><input type="date" name="tanggal" class="form-control" required></div>
        <div class="col-md-2"><input type="number" name="spx" class="form-control" placeholder="SPX"></div>
        <div class="col-md-2"><input type="number" name="jne" class="form-control" placeholder="JNE"></div>
        <div class="col-md-2"><input type="number" name="jnt" class="form-control" placeholder="JNT"></div>
        <div class="col-md-2"><input type="number" name="sameday" class="form-control" placeholder="Same"></div>
        <div class="col-md-1"><button type="submit" class="btn btn-success w-100">OK</button></div>
    </form>
    <table class="table table-hover bg-white shadow-sm rounded overflow-hidden">
        <thead class="table-dark">
            <tr><th>TGL</th><th>SPX</th><th>JNE</th><th>JNT</th><th>SAME</th><th>TOTAL</th><th>AKSI</th></tr>
        </thead>
        <tbody>
            <% dataShipping.forEach(item => { %>
                <tr>
                    <td><%= item.Tanggal %></td><td><%= item.SPX %></td><td><%= item.JNE %></td>
                    <td><%= item.JNT %></td><td><%= item["SAMEDAY/INSTANT"] %></td>
                    <td class="fw-bold"><%= item["TOTAL Paket"] %></td>
                    <td><a href="/hapus/shipping/<%= item.ID %>" class="text-danger" onclick="return confirm('Hapus?')">Del</a></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
</body>
</html>
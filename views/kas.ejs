<%- include('partials/navbar') %>

<div class="container">
    <div class="mb-4">
        <h4 class="fw-bold mb-1">Informasi Mutasi Kas</h4>
        <p class="text-muted small">Update terakhir: <%= new Date().toLocaleDateString('id-ID') %></p>
    </div>

    <div class="card-bank">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tanggal</th>
                        <th>Keterangan</th>
                        <th class="text-end">Nominal</th>
                        <th class="text-center">Bukti</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% dataKas.forEach(item => { %>
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">
                            <%= item.Tanggal ? new Date(item.Tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'short'}) : '-' %>
                        </td>
                        <td>
                            <div class="fw-bold"><%= item.Keterangan %></div>
                            <div class="text-muted" style="font-size:11px">Ref: #<%= item.ID %></div>
                        </td>
                        <td class="text-end">
                            <% if (item.Debet > 0) { %>
                                <span class="text-success fw-bold">+<%= item.Debet.toLocaleString('id-ID') %></span>
                            <% } else { %>
                                <span class="text-danger fw-bold">-<%= item.Kredit.toLocaleString('id-ID') %></span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <% if (item.Bukti) { %>
                                <a href="<%= item.Bukti %>" target="_blank" class="btn btn-sm btn-primary btn-bukti" style="border-radius:20px">Lihat</a>
                            <% } else { %>
                                <span class="text-muted">-</span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <a href="/hapus/kas/<%= item.ID %>" class="text-danger opacity-50" onclick="return confirm('Hapus?')">✖</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-center mt-4 text-muted small">Menampilkan 15 transaksi terbaru</p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<div class="mb-3 d-flex gap-2">
    <input type="month" id="filterBulan" class="form-control" style="width: 200px;">
    <button class="btn btn-primary" onclick="cariData()">Cari Tanggal Lama</button>
</div>

<script>
function cariData() {
    const bulan = document.getElementById('filterBulan').value;
    if(bulan) {
        // Ini akan mengarahkan ke halaman dengan filter (perlu update route di app.js)
        window.location.href = `/?bulan=${bulan}`;
    }
}
</script>
